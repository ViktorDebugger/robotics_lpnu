#!/usr/bin/env bash
set -e

XSOCK=/tmp/.X11-unix
XAUTH=/tmp/.docker.xauth
SERIAL_DEVICE="${SERIAL_DEVICE:-/dev/ttyACM0}"

case "$1" in
    build-docker)
        docker build -t robotics_intro -f docker/Dockerfile .
        ;;
    run)
        serial_args=()
        if [ -e "$SERIAL_DEVICE" ]; then
            serial_args+=(--device="$SERIAL_DEVICE" --group-add dialout)
        else
            echo "Warning: serial device not found at $SERIAL_DEVICE; container will have no USB serial. Set SERIAL_DEVICE or plug the arm." >&2
        fi
        docker run -it --rm \
            --name robotics_intro \
            "${serial_args[@]}" \
            --env="QT_X11_NO_MITSHM=1" \
            --env="DISPLAY" \
            -v "$XSOCK:$XSOCK:rw" \
            -v "$XAUTH:$XAUTH:rw" \
            -v "/tmp/.X11-unix:/tmp/.X11-unix:rw" \
            -v "$(pwd)":/opt/ws/src/code \
            -v /dev/dri:/dev/dri:rw \
            --env="XAUTHORITY=$XAUTH" \
            robotics_intro
        ;;
    bash)
        docker exec -it -w /opt/ws robotics_intro bash -c "source /opt/ros/jazzy/setup.bash && source install/setup.bash 2>/dev/null || true; exec bash"
        ;;
    build-workspace)
        docker exec -it robotics_intro bash -c "cd /opt/ws && colcon build"
        ;;
    *)
        echo "Usage: $0 {build-docker|run|bash|build-workspace}"
        exit 1
        ;;
esac
